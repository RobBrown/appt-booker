# NOTE: This .gitignore file is intended to always be ignored for every type of git push. A second file, .gitpublicignore extends this with additional files. The use case for this is to push Claude documentation files to a private account with a private repo, but when a "public deployment" is made to a second github account with a public repo, these files are not published. The goal is to maintain documentation isolation for public repos by removing AI instructional overhead.

.gitpublicignore

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# private security exception log (never commit)
.sec-exceptions.md

# Sentry CLI
.sentryclirc

# typescript
*.tsbuildinfo
next-env.d.ts
*.swp
