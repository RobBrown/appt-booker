# ============================================================
# APPOINTMENT SCHEDULER — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- HOST IDENTITY ---
HOST_NAME=
HOST_DOMAIN=

# --- GOOGLE API (OAuth2) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=
GMAIL_USER=

# --- ZOOM (Server-to-Server OAuth) ---
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# --- APP CONFIGURATION ---
DEFAULT_LOCATION=
DEFAULT_ADDRESS=
CONTACT_EMAIL=

# --- ANALYTICS ---
NEXT_PUBLIC_GA_ID=

# --- SENTRY ---
SENTRY_DSN=

# --- CRON SECURITY ---
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- DURATION LABELS ---
DURATION_LABEL_15=
DURATION_LABEL_30=
DURATION_LABEL_60=
DURATION_LABEL_120=

# --- WORKING HOURS ---
# Overrides Google Calendar working hours settings. Format: HH:MM (24h)
WORKING_HOURS_START=
WORKING_HOURS_END=
# Overrides Google Calendar timezone setting. IANA format e.g. America/New_York
HOST_TIMEZONE=

# --- BOOKING PAGE CONFIG ---
TOPIC_CHIPS=
LATE_MESSAGE_DELAY_MINUTES=
