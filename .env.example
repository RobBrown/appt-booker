# ============================================================
# APPOINTMENT SCHEDULER — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- HOST IDENTITY ---
HOST_NAME=
HOST_DOMAIN=

# --- GOOGLE API (OAuth2) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=
GMAIL_USER=

# --- ZOOM (Server-to-Server OAuth) ---
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# --- APP CONFIGURATION ---
DEFAULT_LOCATION=
DEFAULT_ADDRESS=
CONTACT_EMAIL=

# --- SENTRY ---
SENTRY_DSN=

# --- CRON SECURITY ---
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- DURATION LABELS ---
DURATION_LABEL_15=
DURATION_LABEL_30=
DURATION_LABEL_60=
DURATION_LABEL_120=

# --- WORKING HOURS ---
# Overrides Google Calendar working hours settings. Format: HH:MM (24h)
WORKING_HOURS_START=
WORKING_HOURS_END=
# Overrides Google Calendar timezone setting. IANA format e.g. America/New_York
HOST_TIMEZONE=

# --- BOOKING PAGE CONFIG ---
TOPIC_CHIPS=
LATE_MESSAGE_DELAY_MINUTES=

# --- CLERK (MCP Server OAuth) ---
# Clerk is used as the OAuth 2.1 authorization server for the MCP endpoint.
# Obtain these from https://dashboard.clerk.com → API Keys.
# Users authenticate via Google or Microsoft — no API keys needed for callers.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- ANTHROPIC (Quinn AI Assistant) ---
# Used by Quinn to parse email intent via Claude.
# Obtain from https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=sk-ant-...
